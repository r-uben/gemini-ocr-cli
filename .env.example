# Gemini OCR CLI Configuration
# Copy this file to .env and fill in your values

# Required: Your Google Gemini API key
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Model to use (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# Optional: Maximum file size in MB (default: 50)
# GEMINI_MAX_FILE_SIZE_MB=50

# Optional: Maximum concurrent workers (default: 1)
# GEMINI_MAX_WORKERS=1

# Optional: Enable verbose output (default: false)
# GEMINI_VERBOSE=false
